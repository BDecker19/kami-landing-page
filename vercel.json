{
  "rewrites": [
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/how-it-works",
      "destination": "/how-it-works.html"
    },
    {
      "source": "/password-reset",
      "destination": "/password-reset.html"
    },
    {
      "source": "/invite/:code",
      "destination": "/invite/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/privacy.html",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/terms.html",
      "destination": "/terms",
      "permanent": true
    },
    {
      "source": "/how-it-works.html",
      "destination": "/how-it-works",
      "permanent": true
    },
    {
      "source": "/password-reset.html",
      "destination": "/password-reset",
      "permanent": true
    }
  ]
}
